{
  "name": "livvie-code-review",
  "version": "1.0.0",
  "description": "AI code review GitHub Action with native suggestion blocks and REQUEST_CHANGES support.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --minify",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@actions/core": "^1.11.0",
    "@actions/github": "^6.0.0",
    "@octokit/rest": "^21.0.0",
    "gpt-tokenizer": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vercel/ncc": "^0.38.0",
    "@vitest/coverage-v8": "^4.1.10",
    "prettier": "^3.9.5",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10"
  }
}
